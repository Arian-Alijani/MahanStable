@model CartViewModel
@{
    ViewData["Title"] = "سبد خرید";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
}

<div class="cart-page" data-cart-page>
    <h1 class="cart-page__title">سبد خرید</h1>

    @if (Model.Lines.Count == 0)
    {
        <div class="cart-empty">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <p>سبد خرید شما خالی است.</p>
            <a class="btn btn-primary" href="/products">مشاهده محصولات</a>
        </div>
    }
    else
    {
        @if (Model.HasUnavailable)
        {
            <div class="cart-alert">برخی اقلام به‌علت تغییر موجودی اصلاح شدند. مبالغ به‌روزرسانی شد.</div>
        }

        <div class="cart-layout">
            <div class="cart-lines">
                @foreach (var line in Model.Lines)
                {
                    <div class="cart-line" data-line data-pid="@line.ProductId" data-vid="@(line.VariantId?.ToString() ?? "")">
                        <a class="cart-line__media" href="/product/@line.Slug">
                            <img src="@(line.ImageUrl ?? "/img/products/p1.svg")" alt="@line.Title" loading="lazy" />
                        </a>
                        <div class="cart-line__info">
                            <a class="cart-line__title" href="/product/@line.Slug">@line.Title</a>
                            @if (line.VariantTitle is not null)
                            {
                                <span class="cart-line__color">@line.VariantTitle</span>
                            }
                            <span class="cart-line__unit">@line.UnitPrice.ToString("#,0") تومان</span>
                        </div>

                        <div class="cart-line__qty">
                            <button type="button" class="qty-btn" data-qty-dec aria-label="کاهش">−</button>
                            <span class="qty-val" data-qty-val>@line.Quantity</span>
                            <button type="button" class="qty-btn" data-qty-inc aria-label="افزایش">+</button>
                        </div>

                        <div class="cart-line__total" data-line-total>@line.LineTotal.ToString("#,0") تومان</div>

                        <button type="button" class="cart-line__remove" data-remove aria-label="حذف">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
                        </button>
                    </div>
                }
            </div>

            <aside class="cart-summary">
                <h2 class="cart-summary__title">خلاصه سفارش</h2>
                <div class="cart-summary__row">
                    <span>تعداد اقلام</span><span data-sum-qty>@Model.TotalQuantity</span>
                </div>
                <div class="cart-summary__row">
                    <span>جمع کل</span><span>@Model.TotalAmount.ToString("#,0") تومان</span>
                </div>
                @if (Model.DiscountAmount > 0)
                {
                    <div class="cart-summary__row cart-summary__row--off">
                        <span>تخفیف</span><span>−@Model.DiscountAmount.ToString("#,0") تومان</span>
                    </div>
                }
                <div class="cart-summary__row cart-summary__row--pay">
                    <span>قابل پرداخت</span><span data-sum-pay>@Model.PayableAmount.ToString("#,0") تومان</span>
                </div>
                <a class="btn btn-primary w-100 mt-3" href="/checkout">ادامه و تسویه</a>
            </aside>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/cart.js" asp-append-version="true"></script>
}
