@model List<MenuCategoryDto>
@{
    // مسیر فعلی برای فعال‌سازی «تمام محصولات» وقتی روی صفحهٔ کاتالوگ بدون دستهٔ خاص هستیم
    var path = (Context.Request.Path.Value ?? string.Empty).TrimEnd('/').ToLowerInvariant();
    var hasCategory = Context.Request.Query.ContainsKey("CategorySlug");
    var allActive = (path == "/products" && !hasCategory);
}

<nav class="mega" aria-label="دسته‌بندی محصولات">
    <ul class="mega-root">
        <li class="mega-item mega-item--all">
            <a class="mega-link mega-link--all @(allActive ? "is-active" : "")" href="/products" aria-current="@(allActive ? "page" : null)">
                <svg class="mega-link__icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
                تمام محصولات
            </a>
        </li>
        @foreach (var c in Model)
        {
            <li class="mega-item">
                <a class="mega-link" href="/products?CategorySlug=@Uri.EscapeDataString(c.Slug)">
                    @c.Name
                    @if (c.Children.Any())
                    {
                        <svg class="mega-caret" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                    }
                </a>
                @if (c.Children.Any())
                {
                    <div class="mega-panel">
                        <ul class="mega-sub">
                            @foreach (var ch in c.Children)
                            {
                                <li><a href="/products?CategorySlug=@Uri.EscapeDataString(ch.Slug)">@ch.Name</a></li>
                            }
                        </ul>
                    </div>
                }
            </li>
        }
    </ul>
</nav>
