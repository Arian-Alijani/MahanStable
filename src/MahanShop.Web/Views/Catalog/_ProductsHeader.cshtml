@model CatalogViewModel
@{
    var f = Model.Applied;

    // chipهای فیلتر فعال — هر کدام لینکی که همان فیلتر را حذف می‌کند
    string baseRoute() => string.IsNullOrWhiteSpace(f.CategorySlug)
        ? Url.RouteUrl("catalog")!
        : Url.RouteUrl("category", new { slug = f.CategorySlug })!;

    string chipUrl(System.Action<CatalogFilter> mutate)
    {
        var clone = new CatalogFilter
        {
            CategorySlug = f.CategorySlug, BrandSlug = f.BrandSlug, ColorId = f.ColorId,
            Search = f.Search, PriceMin = f.PriceMin, PriceMax = f.PriceMax,
            InStockOnly = f.InStockOnly, Sort = f.Sort, PageSize = f.PageSize
        };
        mutate(clone);
        var rv = new Dictionary<string, string?>();
        if (clone.Search is { Length: > 0 }) rv["q"] = clone.Search;
        if (clone.BrandSlug is { Length: > 0 }) rv["BrandSlug"] = clone.BrandSlug;
        if (clone.ColorId is int ci) rv["ColorId"] = ci.ToString();
        if (clone.PriceMin is long pm) rv["PriceMin"] = pm.ToString();
        if (clone.PriceMax is long px) rv["PriceMax"] = px.ToString();
        if (clone.InStockOnly) rv["InStockOnly"] = "true";
        if (clone.Sort != "newest") rv["Sort"] = clone.Sort;
        // مسیر پایه دسته/جستجو را حفظ کن
        if (string.IsNullOrWhiteSpace(f.CategorySlug) && clone.Search is { Length: > 0 })
            return QueryHelpers(Url.RouteUrl("search")!, rv);
        return QueryHelpers(baseRoute(), rv);
    }

    string QueryHelpers(string path, Dictionary<string, string?> rv)
    {
        var qs = string.Join("&", rv.Where(kv => kv.Value is { Length: > 0 })
            .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value!)}"));
        return qs.Length > 0 ? $"{path}?{qs}" : path;
    }

    var activeBrand = Model.Brands.FirstOrDefault(b => b.Active);
    var activeColor = Model.Colors.FirstOrDefault(c => c.Active);
    bool priceActive = (f.PriceMin is long mn && mn > Model.PriceFloor) || (f.PriceMax is long mx && mx < Model.PriceCeil);
}

<div class="products-header">
    <div class="products-header__row">
        <button type="button" class="filter-toggle" id="filter-toggle" aria-controls="filter-sidebar" aria-expanded="false">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
            <span>فیلترها</span>
        </button>

        <div class="products-header__sort">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h13M3 12h9M3 18h5M17 8V4m0 0-3 3m3-3 3 3"/></svg>
            <label for="sort-by">مرتب‌سازی</label>
            <div class="select-wrap">
                <select id="sort-by" name="Sort" class="sort-select" form="catalog-form">
                    <option value="newest" selected="@(f.Sort == "newest")">جدیدترین</option>
                    <option value="oldest" selected="@(f.Sort == "oldest")">قدیمی‌ترین</option>
                    <option value="price-asc" selected="@(f.Sort == "price-asc")">قیمت: کم به زیاد</option>
                    <option value="price-desc" selected="@(f.Sort == "price-desc")">قیمت: زیاد به کم</option>
                    <option value="popular" selected="@(f.Sort == "popular")">محبوب‌ترین</option>
                </select>
                <svg class="select-chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
        </div>

        <span class="products-header__count">@Model.TotalCount.ToString("#,0") محصول</span>
    </div>

    @{
        var chips = new List<(string Label, string Url)>();
        if (!string.IsNullOrWhiteSpace(f.Search))
            chips.Add(($"جستجو: {f.Search}", chipUrl(c => c.Search = null)));
        if (activeBrand != null)
            chips.Add(($"برند: {activeBrand.Name}", chipUrl(c => c.BrandSlug = null)));
        if (activeColor != null)
            chips.Add(($"رنگ: {activeColor.Name}", chipUrl(c => c.ColorId = null)));
        if (priceActive)
            chips.Add(($"قیمت: {(f.PriceMin ?? Model.PriceFloor):#,0} تا {(f.PriceMax ?? Model.PriceCeil):#,0}", chipUrl(c => { c.PriceMin = null; c.PriceMax = null; })));
        if (f.InStockOnly)
            chips.Add(("فقط موجود", chipUrl(c => c.InStockOnly = false)));
    }
    @if (chips.Count > 0)
    {
        <div class="active-filters">
            @foreach (var chip in chips)
            {
                <a class="filter-chip" href="@chip.Url">
                    <span>@chip.Label</span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </a>
            }
            <a class="filter-chip filter-chip--clear" href="@baseRoute()">حذف همه</a>
        </div>
    }
</div>
