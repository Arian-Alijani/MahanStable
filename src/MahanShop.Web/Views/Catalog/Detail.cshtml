@model MahanShop.Application.Features.Catalog.Queries.GetProductDetail.ProductDetailDto
@{
    ViewData["Title"] = string.IsNullOrEmpty(Model.MetaTitle) ? Model.Title : Model.MetaTitle;
    ViewData["MetaDescription"] = Model.MetaDescription
        ?? Model.ShortDescription
        ?? $"خرید {Model.Title} از ماهان شاپ با ضمانت اصالت و ارسال سریع.";

    var mainImg = Model.Images.FirstOrDefault()?.Url ?? "/img/products/p1.svg";
    var catUrl = Url.RouteUrl("category", new { slug = Model.CategorySlug });
}

@section Styles {
    <link rel="stylesheet" href="~/css/product-detail.css" asp-append-version="true" />
}

<div class="container pd">
    <nav class="pd-breadcrumb" aria-label="مسیر">
        <ol>
            <li><a href="/">خانه</a></li>
            <li class="sep">/</li>
            <li><a href="@Url.RouteUrl("catalog")">محصولات</a></li>
            <li class="sep">/</li>
            <li><a href="@catUrl">@Model.CategoryName</a></li>
            <li class="sep">/</li>
            <li class="current">@Model.Title</li>
        </ol>
    </nav>

    <section class="pd-grid" data-pd>
        @* ---- گالری ---- *@
        <div class="pd-col pd-col--gallery">
            <div class="pd-card">
                <div class="pd-media">
                    <img id="pd-main-image" class="pd-main-image" src="@mainImg" alt="@Model.Title" loading="eager" decoding="async" />
                    @if (Model.HasDiscount)
                    {
                        <span class="pd-badge">@Model.DiscountPercent٪ تخفیف</span>
                    }
                    @if (Model.Images.Count > 1)
                    {
                        <button class="pd-nav-btn pd-nav-btn--prev" type="button" data-pd-prev aria-label="تصویر قبلی">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 6 6 6-6 6"/></svg>
                        </button>
                        <button class="pd-nav-btn pd-nav-btn--next" type="button" data-pd-next aria-label="تصویر بعدی">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m15 6-6 6 6 6"/></svg>
                        </button>
                    }
                </div>

                @if (Model.Images.Count > 1)
                {
                    <div class="pd-thumbs" aria-label="تصاویر محصول">
                        @for (var i = 0; i < Model.Images.Count; i++)
                        {
                            var im = Model.Images[i];
                            <button class="pd-thumb @(i == 0 ? "is-active" : "")" type="button" data-pd-thumb data-full-src="@im.Url" aria-label="تصویر @(i + 1)">
                                <img src="@im.Url" alt="@(im.Alt ?? Model.Title)" loading="lazy" />
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        @* ---- اطلاعات ---- *@
        <div class="pd-col pd-col--info">
            <div class="pd-card">
                <h1 class="pd-title">@Model.Title</h1>

                <p class="pd-subtitle">
                    @if (!string.IsNullOrEmpty(Model.BrandName))
                    {
                        <span>برند: <a class="pd-brand" href="@Url.RouteUrl("catalog")?BrandSlug=@Model.BrandSlug">@Model.BrandName</a></span>
                    }
                    <span class="pd-sep">|</span>
                    <span>کد کالا: <b>@Model.Id</b></span>
                </p>

                @if (Model.Tags.Count > 0)
                {
                    <div class="pd-tags">
                        @foreach (var t in Model.Tags)
                        {
                            <span class="pd-tag">@t.Name</span>
                        }
                    </div>
                }

                <hr class="pd-divider" />

                @if (Model.HasVariants)
                {
                    foreach (var attr in Model.Attributes)
                    {
                        <div class="pd-field" data-pd-attr="@attr.Id">
                            <span class="pd-field__label">@attr.Name</span>
                            <div class="@(attr.IsColor ? "pd-colors" : "pd-options")">
                                @foreach (var v in attr.Values)
                                {
                                    if (attr.IsColor)
                                    {
                                        <label class="pd-color" title="@v.Value" aria-label="@v.Value">
                                            <input type="radio" name="pd-attr-@attr.Id" value="@v.Id" data-pd-value />
                                            <span class="pd-color__dot" style="background:@(v.ColorHex ?? "#888")"></span>
                                        </label>
                                    }
                                    else
                                    {
                                        <label class="pd-option">
                                            <input type="radio" name="pd-attr-@attr.Id" value="@v.Id" data-pd-value />
                                            <span class="pd-option__txt">@v.Value</span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>
                    }
                    <p class="pd-variant-hint" data-pd-hint hidden>لطفاً همه گزینه‌ها را انتخاب کنید.</p>
                }

                @if (!string.IsNullOrEmpty(Model.ShortDescription))
                {
                    <div class="pd-field">
                        <span class="pd-field__label">معرفی کوتاه</span>
                        <p class="pd-short">@Model.ShortDescription</p>
                    </div>
                }

                @if (Model.Features.Count > 0)
                {
                    <div class="pd-field">
                        <span class="pd-field__label">ویژگی‌های کلیدی</span>
                        <ul class="pd-bullets">
                            @foreach (var f in Model.Features.Take(5))
                            {
                                <li class="pd-bullet">@f.Name: @f.Value</li>
                            }
                        </ul>
                    </div>
                }

                <div class="pd-stock @(Model.InStock ? "is-in" : "is-out")">
                    @if (Model.InStock)
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                        <span>موجود در انبار</span>
                    }
                    else
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                        <span>ناموجود</span>
                    }
                </div>
            </div>
        </div>

        @* ---- جعبه خرید ---- *@
        <div class="pd-col pd-col--buy">
            <div class="pd-card pd-buy">
                <div class="pd-buy__head">
                    <div class="pd-buy__price">
                        <span class="pd-buy__k">قیمت</span>
                        <span class="pd-buy__old" data-pd-old hidden="@(!Model.HasDiscount)">@Model.Price.ToString("#,0")</span>
                        <div class="pd-buy__now">
                            <b data-pd-price>@Model.FinalPrice.ToString("#,0")</b> <span class="pd-buy__unit">تومان</span>
                        </div>
                    </div>
                    <div class="pd-buy__ship">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7M5.5 21a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5zM18.5 21a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/></svg>
                        <span>ارسال سریع</span>
                    </div>
                </div>

                <hr class="pd-divider" />

                <button class="pd-cta @(Model.InStock ? "" : "is-disabled")" type="button"
                        data-add="@Model.Id"
                        @(Model.HasVariants ? "data-has-variants" : "")
                        data-pd-cta
                        @(Model.InStock ? "" : "disabled")>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
                    <span data-pd-cta-label>@(Model.InStock ? "افزودن به سبد خرید" : "ناموجود")</span>
                </button>

                @if (Model.HasVariants)
                {
                    <script type="application/json" data-pd-variants>
                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Variants.Select(v => new {
                            id = v.Id,
                            price = v.Price,
                            final = v.FinalPrice,
                            hasDiscount = v.DiscountPrice is > 0 && v.DiscountPrice < v.Price,
                            stock = v.Stock,
                            values = v.ValueIds
                        })))
                    </script>
                }

                <ul class="pd-perks">
                    <li>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
                        ضمانت اصالت و سلامت کالا
                    </li>
                    <li>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11a9 9 0 0 1 18 0v5a2 2 0 0 1-2 2h-1v-7M5 18H4a2 2 0 0 1-2-2v-1"/></svg>
                        پشتیبانی ۲۴ ساعته
                    </li>
                </ul>
            </div>
        </div>

        @* ---- تب‌ها ---- *@
        <div class="pd-col pd-col--tabs">
            <div class="pd-card">
                <div class="pd-tabs" role="tablist" aria-label="اطلاعات محصول">
                    <button class="pd-tab is-active" type="button" role="tab" aria-selected="true" data-pd-tab="desc">معرفی</button>
                    @if (Model.Features.Count > 0)
                    {
                        <button class="pd-tab" type="button" role="tab" aria-selected="false" data-pd-tab="specs">مشخصات</button>
                    }
                </div>

                <div class="pd-tabwrap">
                    <section class="pd-panel is-active" role="tabpanel" data-pd-panel="desc">
                        <h2 class="pd-panel__title">معرفی محصول</h2>
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p class="pd-desc">@Model.Description</p>
                        }
                        else if (!string.IsNullOrEmpty(Model.ShortDescription))
                        {
                            <p class="pd-desc">@Model.ShortDescription</p>
                        }
                        else
                        {
                            <p class="pd-desc pd-desc--muted">توضیحاتی برای این محصول ثبت نشده است.</p>
                        }
                    </section>

                    @if (Model.Features.Count > 0)
                    {
                        <section class="pd-panel" role="tabpanel" data-pd-panel="specs" hidden>
                            <h2 class="pd-panel__title">مشخصات فنی</h2>
                            <div class="pd-specs">
                                @foreach (var f in Model.Features)
                                {
                                    <div class="pd-spec">
                                        <span class="pd-spec__k">@f.Name</span>
                                        <span class="pd-spec__v">@f.Value</span>
                                    </div>
                                }
                            </div>
                        </section>
                    }
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org/",
      "@@type": "Product",
      "name": "@Model.Title",
      "sku": "@Model.Id",
      @if (!string.IsNullOrEmpty(Model.BrandName))
      {
        <text>"brand": { "@@type": "Brand", "name": "@Model.BrandName" },</text>
      }
      "offers": {
        "@@type": "Offer",
        "priceCurrency": "IRT",
        "price": "@Model.FinalPrice",
        "availability": "@(Model.InStock ? "https://schema.org/InStock" : "https://schema.org/OutOfStock")"
      }
    }
    </script>
}
