@model HomePageViewModel
@{
    ViewData["Title"] = null; // عنوان پیش‌فرض صفحه اصلی در Layout
    ViewData["MetaDescription"] = "فروشگاه اینترنتی ماهان شاپ؛ خرید گوشی موبایل، قاب، شارژر، هندزفری و گجت اصل با ضمانت اصالت، قیمت مناسب و ارسال سریع.";
}

<h1 class="visually-hidden">فروشگاه اینترنتی موبایل و لوازم جانبی ماهان شاپ</h1>

<div class="container home">
    @await Html.PartialAsync("_HeroBanner", Model.Banners)
    @await Html.PartialAsync("_CategoryGrid", Model.FeaturedCategories)

    @{
        // رندر یکپارچهٔ بدنه: نوارهای محصول و بنرهای میانی در یک ترتیب مشترک (DisplayOrder).
        // بنرهایی که عدد ترتیب یکسان دارند، در یک ردیف کنار هم با تقسیم مساویِ فضا قرار می‌گیرند.
        var sections = Model.Sections;
        for (var i = 0; i < sections.Count; i++)
        {
            var s = sections[i];

            if (s.SectionType == HomeSectionType.ProductRow)
            {
                @await Html.PartialAsync("_ProductRow", s)
                continue;
            }

            // PromoBanner — گروه‌بندی بنرهای هم‌ردیف (DisplayOrder یکسان) در یک ردیف
            var group = new List<HomeSectionViewModel> { s };
            while (i + 1 < sections.Count
                && sections[i + 1].SectionType == HomeSectionType.PromoBanner
                && sections[i + 1].DisplayOrder == s.DisplayOrder)
            {
                group.Add(sections[i + 1]);
                i++;
            }

            if (group.Count == 1)
            {
                @await Html.PartialAsync("_PromoBanner", group[0])
            }
            else
            {
                <div class="promo-row" style="--cols:@group.Count">
                    @foreach (var g in group)
                    {
                        @await Html.PartialAsync("_PromoBanner", g)
                    }
                </div>
            }
        }
    }
</div>
