@model List<HomeBannerDto>
@if (Model.Count == 0) { return; }

<section class="hero" data-hero aria-label="بنرهای ویژه" aria-roledescription="carousel">
    <div class="hero__viewport">
        @for (var i = 0; i < Model.Count; i++)
        {
            var b = Model[i];
            <a class="hero__slide @(i == 0 ? "is-active" : "")" data-hero-slide href="@(b.LinkUrl ?? "#")" aria-hidden="@(i == 0 ? "false" : "true")">
                <picture>
                    @if (!string.IsNullOrEmpty(b.MobileImageUrl))
                    {
                        <source media="(max-width: 640px)" srcset="@b.MobileImageUrl" />
                    }
                    <img src="@b.ImageUrl" alt="@b.AltText" loading="@(i == 0 ? "eager" : "lazy")" decoding="async" />
                </picture>
            </a>
        }
    </div>

    @if (Model.Count > 1)
    {
        @* نوار نشانگر — هر قطعه یک اسلاید؛ قطعهٔ فعال پُر می‌شود و با کلیک جابجا می‌شود *@
        <div class="hero__bars" role="tablist" aria-label="انتخاب بنر">
            @for (var i = 0; i < Model.Count; i++)
            {
                <button type="button" class="hero__bar @(i == 0 ? "is-active" : "")" data-hero-bar
                        role="tab" aria-selected="@(i == 0 ? "true" : "false")"
                        aria-label="بنر @(i + 1) از @Model.Count">
                    <span class="hero__bar-fill"></span>
                </button>
            }
        </div>
    }
</section>
