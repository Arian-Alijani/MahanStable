@model List<HomeBannerDto>
@if (Model.Count == 0) { return; }

<section class="hero" data-hero aria-label="بنرهای ویژه">
    <div class="hero__viewport">
        @for (var i = 0; i < Model.Count; i++)
        {
            var b = Model[i];
            <a class="hero__slide @(i == 0 ? "is-active" : "")" data-hero-slide href="@(b.LinkUrl ?? "#")" aria-hidden="@(i == 0 ? "false" : "true")">
                <picture>
                    @if (!string.IsNullOrEmpty(b.MobileImageUrl))
                    {
                        <source media="(max-width: 640px)" srcset="@b.MobileImageUrl" />
                    }
                    <img src="@b.ImageUrl" alt="@b.AltText" loading="@(i == 0 ? "eager" : "lazy")" decoding="async" />
                </picture>
            </a>
        }
    </div>

    @* دکمه‌های جابجایی (فلش/نقطه) به‌خواست کاربر حذف شدند؛ بنر هر ۱۵ ثانیه خودکار عوض می‌شود. *@
</section>
