@{
    var active = ViewData["AdminActive"] as string ?? "dashboard";
    var name = User.Identity?.Name ?? "مدیر";
    // زیرمنوی «تنظیمات بیشتر» وقتی روی صفحهٔ مدیریت صفحهٔ اصلی هستیم باز بماند.
    var moreOpen = active == "home";
}
<aside class="admin-aside" id="adminAside">
    <div class="admin-brand">
        <span class="admin-brand__dot"></span>
        <span>پنل مدیریت</span>
    </div>
    <div class="admin-user">
        <div class="admin-user__avatar">@((name.Length > 0 ? name.Substring(0, 1) : "م"))</div>
        <div class="admin-user__meta">
            <div class="admin-user__name">@name</div>
            <div class="admin-user__role">مدیر سیستم</div>
        </div>
    </div>

    <nav class="admin-nav" aria-label="ناوبری اصلی پنل">
        @* ۱) داشبورد *@
        <a class="admin-nav__link @(active == "dashboard" ? "is-active" : "")" href="/Admin">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
            <span>داشبورد</span>
        </a>

        @* ۲) محصولات *@
        <a class="admin-nav__link @(active == "products" ? "is-active" : "")" href="/Admin/Products">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            <span>محصولات</span>
        </a>

        @* ۳) مدیریت موجودی *@
        <a class="admin-nav__link @(active == "inventory" ? "is-active" : "")" href="/Admin/Inventory">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            <span>مدیریت موجودی</span>
        </a>

        @* ۴) کنترل ویژگی (hub: برند/مدل/مشخصات‌فنی/تگ/دسته/نوع‌پست) *@
        <a class="admin-nav__link @(active == "attributes" ? "is-active" : "")" href="/Admin/Attributes">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/><circle cx="17" cy="7" r="1.4" fill="currentColor" stroke="none"/></svg>
            <span>کنترل ویژگی</span>
        </a>

        @* ۵) سفارش‌ها *@
        <a class="admin-nav__link @(active == "orders" ? "is-active" : "")" href="/Admin/Orders">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span>سفارش‌ها</span>
        </a>

        @* ۶) کاربران *@
        <a class="admin-nav__link @(active == "users" ? "is-active" : "")" href="/Admin/Users">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>کاربران</span>
        </a>

        @* ── تنظیمات بیشتر (زیرمنوی جمع‌شونده) — قابلیت «مدیریت صفحهٔ اصلی» اینجا حفظ می‌شود ── *@
        <div class="admin-nav__group @(moreOpen ? "is-open" : "")" id="adminMoreGroup">
            <button type="button" class="admin-nav__link admin-nav__toggle" aria-expanded="@(moreOpen ? "true" : "false")" aria-controls="adminMorePanel" onclick="this.closest('.admin-nav__group').classList.toggle('is-open'); this.setAttribute('aria-expanded', this.closest('.admin-nav__group').classList.contains('is-open'));">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                <span>تنظیمات بیشتر</span>
                <svg class="admin-nav__chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="admin-nav__sub" id="adminMorePanel">
                <a class="admin-nav__sublink @(active == "home" ? "is-active" : "")" href="/Admin/Home">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    <span>مدیریت صفحهٔ اصلی</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="admin-aside__foot">
        <a class="admin-nav__link admin-nav__link--store" href="/" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l1-5h16l1 5"/><path d="M4 9v11a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V9"/><path d="M3 9h18"/><path d="M9 21v-6h6v6"/></svg>
            <span>بازگشت به فروشگاه</span>
        </a>
        <form method="post" action="/Account/Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="admin-nav__link is-danger">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                <span>خروج</span>
            </button>
        </form>
    </div>
</aside>
