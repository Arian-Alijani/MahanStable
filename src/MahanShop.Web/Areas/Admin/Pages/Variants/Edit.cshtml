@page "{id:int}"
@model MahanShop.Web.Areas.Admin.Pages.Variants.EditModel
@{
    ViewData["Title"] = "ویرایش ویژگی";
    ViewData["AdminActive"] = "attributes";
}

<div class="admin-panel-box admin-form">
    <div asp-validation-summary="All" class="text-danger"></div>
    <form method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label class="form-label">نام ویژگی</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">نقش ویژگی</label>
            <select asp-for="Kind" class="form-select">
                <option value="0">عمومی — دراپ‌داون</option>
                <option value="1">برند دستگاه</option>
                <option value="2">مدل دستگاه</option>
                <option value="3">رنگ (swatch)</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">ترتیب نمایش</label>
            <input asp-for="DisplayOrder" type="number" class="form-control" />
        </div>
        <div class="form-check mb-3">
            <input asp-for="IsColor" class="form-check-input" />
            <label class="form-check-label">ویژگی رنگ است (نمایش swatch)</label>
        </div>
        <div class="admin-form__actions">
            <button type="submit" class="btn btn-primary">ذخیره</button>
            <a asp-page="Index" class="btn btn-outline-secondary">انصراف</a>
        </div>
    </form>
</div>
