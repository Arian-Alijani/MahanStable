@page "{id:int}"
@using MahanShop.Web.Helpers
@model MahanShop.Web.Areas.Admin.Pages.Users.DetailModel
@{
    var u = Model.Detail;
    var displayName = string.IsNullOrEmpty(u.FullName) ? u.PhoneNumber : u.FullName;
    ViewData["Title"] = displayName;
    ViewData["AdminActive"] = "users";
    var initials = string.IsNullOrEmpty(u.FullName)
        ? (u.PhoneNumber.Length >= 2 ? u.PhoneNumber[..2] : u.PhoneNumber)
        : (u.FullName.Length >= 2 ? u.FullName[..2] : u.FullName);
}

@if (TempData["AdminOk"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["AdminError"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

@* ── سربرگ ── *@
<div class="u9-detail-head">
    <div class="u9-detail-avatar-group">
        <div class="u9-detail-avatar">@initials</div>
        <div>
            <h2 class="admin-page-title" style="margin-bottom:4px">@displayName</h2>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                @if (u.IsAdmin)
                {
                    <span class="badge admin-status-badge is-info">مدیر</span>
                }
                @if (u.IsActive)
                {
                    <span class="badge admin-status-badge is-success">فعال</span>
                }
                else
                {
                    <span class="badge admin-status-badge is-danger">غیرفعال</span>
                }
                <span class="admin-muted" style="font-size:13px">@u.TotalOrderCount سفارش</span>
            </div>
        </div>
    </div>
    <a asp-page="Index" class="btn btn-outline-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6" />
        </svg>
        بازگشت به لیست
    </a>
</div>

@* ── گرید بالا: اطلاعات + مدیریت دسترسی + حذف ── *@
<div class="admin-grid-2" style="margin-bottom:18px">
    @* اطلاعات کاربر *@
    <div class="admin-panel-box">
        <h3 class="admin-box-title">اطلاعات کاربر</h3>
        <dl class="admin-dl">
            <dt>موبایل</dt>
            <dd><span class="u9-phone">@u.PhoneNumber</span></dd>
            @if (!string.IsNullOrEmpty(u.Email))
            {
                <dt>ایمیل</dt>
                <dd>@u.Email</dd>
            }
            <dt>تاریخ عضویت</dt>
            <dd>@u.CreatedAt.ToString("yyyy/MM/dd HH:mm")</dd>
            <dt>تعداد سفارش</dt>
            <dd>@u.TotalOrderCount سفارش</dd>
            <dt>تعداد آدرس</dt>
            <dd>@u.Addresses.Count آدرس</dd>
        </dl>
    </div>

    @* مدیریت دسترسی + حذف *@
    <div class="admin-panel-box">
        <h3 class="admin-box-title">مدیریت دسترسی</h3>
        <div class="u9-access-actions">
            <form method="post" asp-page-handler="ToggleAdmin" asp-route-id="@u.Id">
                <button type="submit" class="btn u9-access-btn @(u.IsAdmin ? "btn-outline-danger" : "btn-outline-primary")">
                    @if (u.IsAdmin)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
                        </svg>
                        <span>سلب نقش مدیر</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
                        </svg>
                        <span>اعطای نقش مدیر</span>
                    }
                </button>
            </form>
            <form method="post" asp-page-handler="ToggleActive" asp-route-id="@u.Id">
                <button type="submit" class="btn u9-access-btn @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                    @if (u.IsActive)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                        </svg>
                        <span>غیرفعال‌سازی حساب</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        <span>فعال‌سازی حساب</span>
                    }
                </button>
            </form>
        </div>
        <p class="admin-muted" style="font-size:12.5px;margin-top:10px">نمی‌توانید نقش یا وضعیت حساب خودتان را تغییر دهید. آخرین مدیر سیستم قابل سلب دسترسی نیست.</p>

        @* حذف کاربر — فقط اگر سفارش ندارد *@
        @if (u.TotalOrderCount == 0)
        {
            <hr style="margin:16px 0;border-color:#f1f5f9" />
            <div class="u9-danger-zone">
                <p class="u9-danger-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    ناحیه خطر
                </p>
                <form method="post" asp-page-handler="DeleteUser" asp-route-id="@u.Id"
                      onsubmit="return confirm('آیا مطمئن هستید؟ کاربر «@displayName» برای همیشه حذف می‌شود.');">
                    <button type="submit" class="btn btn-sm btn-danger">حذف کاربر</button>
                </form>
            </div>
        }
        else
        {
            <p class="admin-muted" style="font-size:12px;margin-top:10px;border-top:1px solid #f1f5f9;padding-top:10px">
                این کاربر @u.TotalOrderCount سفارش دارد و قابل حذف نیست. برای حذف دسترسی، حساب را غیرفعال کنید.
            </p>
        }
    </div>
</div>

@* ── آدرس‌ها ── *@
<div class="admin-panel-box" style="margin-bottom:18px">
    <h3 class="admin-box-title">
        آدرس‌ها
        <span class="u9-count-badge">@u.Addresses.Count</span>
    </h3>
    @if (u.Addresses.Count == 0)
    {
        <p class="admin-muted text-center" style="padding:24px 0">آدرسی ثبت نشده.</p>
    }
    else
    {
        <table class="table admin-table">
            <thead>
                <tr><th>گیرنده</th><th>استان/شهر</th><th>آدرس</th><th>کد پستی</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var a in u.Addresses)
            {
                <tr>
                    <td>@a.ReceiverName<br /><span class="admin-muted">@a.ReceiverPhone</span></td>
                    <td>@a.Province، @a.City</td>
                    <td>@a.FullAddress</td>
                    <td>@a.PostalCode</td>
                    <td class="admin-actions">
                        <form method="post" asp-page-handler="DeleteAddress" asp-route-id="@u.Id" asp-route-addressId="@a.Id"
                              onsubmit="return confirm('این آدرس حذف شود؟');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>

@* ── سفارش‌های اخیر ── *@
<div class="admin-panel-box">
    <h3 class="admin-box-title">
        سفارش‌ها
        <span class="u9-count-badge">@u.TotalOrderCount</span>
    </h3>
    @if (u.RecentOrders.Count == 0)
    {
        <p class="admin-muted text-center" style="padding:24px 0">سفارشی ثبت نشده.</p>
    }
    else
    {
        <table class="table admin-table">
            <thead>
                <tr><th>کد سفارش</th><th>تاریخ</th><th>مبلغ (تومان)</th><th>وضعیت</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var o in u.RecentOrders)
            {
                <tr>
                    <td><strong>@o.OrderCode</strong></td>
                    <td>@o.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                    <td>@o.FinalAmount.ToString("N0")</td>
                    <td><span class="badge admin-status-badge @OrderStatusView.Tone(o.Status)">@OrderStatusView.Label(o.Status)</span></td>
                    <td class="admin-actions">
                        <a asp-area="Admin" asp-page="/Orders/Detail" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">جزییات</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (u.TotalOrderCount > u.RecentOrders.Count)
        {
            <p class="admin-muted text-center" style="font-size:13px;padding:10px 0">
                نمایش @u.RecentOrders.Count سفارش آخر از @u.TotalOrderCount سفارش کل.
            </p>
        }
    }
</div>
