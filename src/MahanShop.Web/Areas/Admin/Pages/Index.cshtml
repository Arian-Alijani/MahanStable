@page
@using MahanShop.Web.Helpers
@model MahanShop.Web.Areas.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "داشبورد";
    ViewData["AdminActive"] = "dashboard";
}

<div class="admin-stats">
    <div class="admin-stat-card">
        <div class="admin-stat-card__label">فروش امروز</div>
        <div class="admin-stat-card__value">@Model.Stats.TodaySales.ToString("N0") <span class="admin-stat-card__unit">تومان</span></div>
    </div>
    <div class="admin-stat-card">
        <div class="admin-stat-card__label">سفارش‌های منتظر پردازش</div>
        <div class="admin-stat-card__value">@Model.Stats.PendingProcessingCount.ToString("N0")</div>
    </div>
    <div class="admin-stat-card">
        <div class="admin-stat-card__label">موجودی کم</div>
        <div class="admin-stat-card__value">@Model.Stats.LowStockCount.ToString("N0")</div>
    </div>
    <div class="admin-stat-card">
        <div class="admin-stat-card__label">کل محصولات فعال</div>
        <div class="admin-stat-card__value">@Model.Stats.ProductCount.ToString("N0")</div>
    </div>
</div>

<div class="admin-stats admin-stats--secondary">
    <div class="admin-stat-card admin-stat-card--soft">
        <div class="admin-stat-card__label">فروش کل</div>
        <div class="admin-stat-card__value">@Model.Stats.TotalSales.ToString("N0") <span class="admin-stat-card__unit">تومان</span></div>
    </div>
    <div class="admin-stat-card admin-stat-card--soft">
        <div class="admin-stat-card__label">سفارش‌های امروز</div>
        <div class="admin-stat-card__value">@Model.Stats.TodayOrderCount.ToString("N0")</div>
    </div>
    <div class="admin-stat-card admin-stat-card--soft">
        <div class="admin-stat-card__label">کل کاربران</div>
        <div class="admin-stat-card__value">@Model.Stats.UserCount.ToString("N0")</div>
    </div>
</div>

<div class="admin-dashboard-grid">
    <div class="admin-panel-box">
        <div class="admin-panel-box__head">
            <h2 class="admin-panel-box__title">سفارش‌های اخیر</h2>
            <a class="btn btn-sm btn-outline-primary" href="/Admin/Orders">همه سفارش‌ها</a>
        </div>
        <table class="table admin-table">
            <thead>
                <tr><th>کد سفارش</th><th>مشتری</th><th>تاریخ</th><th>مبلغ</th><th>وضعیت</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var o in Model.Stats.RecentOrders)
            {
                <tr>
                    <td><strong>@o.OrderCode</strong></td>
                    <td>@o.CustomerName</td>
                    <td>@o.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                    <td>@o.FinalAmount.ToString("N0")</td>
                    <td><span class="badge admin-status-badge @OrderStatusView.Tone(o.Status)">@OrderStatusView.Label(o.Status)</span></td>
                    <td class="admin-actions"><a asp-area="Admin" asp-page="/Orders/Detail" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">جزییات</a></td>
                </tr>
            }
            @if (Model.Stats.RecentOrders.Count == 0)
            {
                <tr><td colspan="6" class="admin-muted text-center">سفارشی ثبت نشده است.</td></tr>
            }
            </tbody>
        </table>
    </div>

    <div class="admin-panel-box">
        <div class="admin-panel-box__head">
            <h2 class="admin-panel-box__title">موجودی کم</h2>
            <a class="btn btn-sm btn-outline-primary" href="/Admin/Products">محصولات</a>
        </div>
        <table class="table admin-table">
            <thead>
                <tr><th>محصول</th><th>گزینه</th><th>موجودی</th></tr>
            </thead>
            <tbody>
            @foreach (var p in Model.Stats.LowStockProducts)
            {
                <tr>
                    <td>@p.Title</td>
                    <td>@(string.IsNullOrEmpty(p.VariantTitle) ? "—" : p.VariantTitle)</td>
                    <td><span class="badge admin-status-badge is-danger">@p.Stock</span></td>
                </tr>
            }
            @if (Model.Stats.LowStockProducts.Count == 0)
            {
                <tr><td colspan="3" class="admin-muted text-center">موردی برای نمایش نیست.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
