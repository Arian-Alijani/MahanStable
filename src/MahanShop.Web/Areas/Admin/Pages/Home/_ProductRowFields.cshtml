@using MahanShop.Domain.Enums
@using MahanShop.Application.Features.Admin.Categories
@{
    var source = (HomeProductSource)(ViewData["Source"] ?? HomeProductSource.Featured);
    var categoryId = ViewData["CategoryId"] as int?;
    var options = ViewData["CategoryOptions"] as List<CategoryOptionDto> ?? new();
    var title = ViewData["Title2"] as string ?? "";
    var maxItems = ViewData["MaxItems"] as int? ?? 10;
    var order = ViewData["DisplayOrder"] as int? ?? 0;
    var isActive = ViewData["IsActive"] as bool? ?? true;
}

<div class="mb-3">
    <label class="form-label">عنوان نوار</label>
    <input name="Title" value="@title" maxlength="150" class="form-control" placeholder="مثلاً: جدیدترین محصولات" required />
</div>

<div class="mb-3">
    <label class="form-label">منبع محصولات</label>
    <select name="ProductSource" class="form-select" data-source-select>
        <option value="@((int)HomeProductSource.Featured)" selected="@(source == HomeProductSource.Featured)">پیشنهادی</option>
        <option value="@((int)HomeProductSource.BestSelling)" selected="@(source == HomeProductSource.BestSelling)">پرفروش‌ترین</option>
        <option value="@((int)HomeProductSource.Newest)" selected="@(source == HomeProductSource.Newest)">جدیدترین</option>
        <option value="@((int)HomeProductSource.Discounted)" selected="@(source == HomeProductSource.Discounted)">تخفیف‌دار</option>
        <option value="@((int)HomeProductSource.ByCategory)" selected="@(source == HomeProductSource.ByCategory)">بر اساس دسته‌بندی</option>
    </select>
</div>

<div class="mb-3" data-category-field style="@(source == HomeProductSource.ByCategory ? "" : "display:none")">
    <label class="form-label">دسته‌بندی</label>
    <select name="CategoryId" class="form-select">
        <option value="">— انتخاب دسته —</option>
        @foreach (var o in options)
        {
            <option value="@o.Id" selected="@(categoryId == o.Id)">@(new string('—', o.Depth)) @o.Name</option>
        }
    </select>
</div>

<div class="row">
    <div class="col mb-3">
        <label class="form-label">حداکثر تعداد محصول (۱ تا ۳۰)</label>
        <input name="MaxItems" type="number" min="1" max="30" value="@maxItems" class="form-control" />
    </div>
    <div class="col mb-3">
        <label class="form-label">عدد ترتیب (۱ = بالاترین)</label>
        <input name="DisplayOrder" type="number" min="0" value="@order" class="form-control" />
    </div>
</div>

<div class="form-check mb-3">
    <input name="IsActive" value="true" type="checkbox" class="form-check-input" checked="@isActive" />
    <label class="form-check-label">فعال (روی صفحهٔ اصلی نمایش داده شود)</label>
</div>
