@page
@model MahanShop.Web.Areas.Admin.Pages.Home.IndexModel
@{
    ViewData["Title"] = "صفحه اصلی";
    ViewData["AdminActive"] = "home";
}

<div class="admin-panel-box">
    <div class="admin-panel-box__head">
        <h2 class="admin-box-title">مدیریت صفحه اصلی</h2>
    </div>

    <div class="admin-empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        <p class="admin-muted">
            این بخش برای مدیریت محتوای صفحهٔ اصلی فروشگاه در نظر گرفته شده است.
            <br />
            در آینده ابزارهای کنترل صفحهٔ اصلی (مدیریت بنرها، چیدمان سکشن‌ها و دسته‌های منتخب) اینجا اضافه خواهند شد.
        </p>
    </div>
</div>
