@page
@model MahanShop.Web.Areas.Admin.Pages.Brands.IndexModel
@{
    ViewData["Title"] = "برندها";
    ViewData["AdminActive"] = "brands";
}

@if (TempData["AdminOk"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}

<div class="admin-toolbar">
    <form method="get" class="admin-search">
        <input type="text" name="Search" value="@Model.Search" class="form-control" placeholder="جستجوی برند..." />
        <button type="submit" class="btn btn-outline-secondary">جستجو</button>
    </form>
    <a asp-page="Create" class="btn btn-primary">برند جدید</a>
</div>

<div class="admin-panel-box">
    <table class="table admin-table">
        <thead>
            <tr>
                <th>لوگو</th><th>نام</th><th>نامک</th><th>محصولات</th><th>ترتیب</th><th>وضعیت</th><th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var b in Model.Brands)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(b.LogoUrl))
                    {
                        <img src="@b.LogoUrl" alt="@b.Name" class="admin-thumb" />
                    }
                    else { <span class="admin-muted">—</span> }
                </td>
                <td>@b.Name</td>
                <td><code>@b.Slug</code></td>
                <td>@b.ProductCount</td>
                <td>@b.DisplayOrder</td>
                <td>
                    @if (b.IsActive) { <span class="badge bg-success">فعال</span> }
                    else { <span class="badge bg-secondary">غیرفعال</span> }
                </td>
                <td class="admin-actions">
                    <a asp-page="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                    <form method="post" asp-page-handler="Toggle" asp-route-id="@b.Id" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-warning">
                            @(b.IsActive ? "غیرفعال" : "فعال")
                        </button>
                    </form>
                </td>
            </tr>
        }
        @if (Model.Brands.Count == 0)
        {
            <tr><td colspan="7" class="admin-muted text-center">برندی یافت نشد.</td></tr>
        }
        </tbody>
    </table>
</div>
