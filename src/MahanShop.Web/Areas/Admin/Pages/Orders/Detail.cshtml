@page "{id:int}"
@using MahanShop.Web.Helpers
@model MahanShop.Web.Areas.Admin.Pages.Orders.DetailModel
@{
    var o = Model.Detail.Order;
    ViewData["Title"] = $"سفارش {o.OrderCode}";
    ViewData["AdminActive"] = "orders";

    var adminTargets = new[]
    {
        OrderStatus.Processing, OrderStatus.Shipped, OrderStatus.Delivered,
        OrderStatus.Canceled, OrderStatus.Refunded
    };

    bool isPaid = o.PaidAt is not null;
    bool hasTracking = !string.IsNullOrEmpty(o.TrackingCode);
}

@if (TempData["AdminOk"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["AdminError"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

@* ── سربرگ *@
<div class="orders8-detail-head">
    <div class="orders8-detail-title">
        <a asp-page="Index" class="orders8-back-btn" title="بازگشت به لیست">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18 6-6-6-6"/><path d="M9 6H3v12h6"/></svg>
        </a>
        <h2 class="admin-page-title">
            سفارش @o.OrderCode
            <span class="badge admin-status-badge @OrderStatusView.Tone(o.Status)">@OrderStatusView.Label(o.Status)</span>
        </h2>
    </div>
    <div class="orders8-detail-actions">
        <a asp-page="Detail" asp-page-handler="Invoice" asp-route-id="@o.Id" class="btn btn-outline-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            فاکتور PDF
        </a>
    </div>
</div>

@* ── خلاصه وضعیت (progress bar) *@
<div class="orders8-progress-bar admin-panel-box" style="margin-bottom:16px">
    @{
        var steps = new (OrderStatus S, string Label)[]
        {
            (OrderStatus.Paid,       "پرداخت"),
            (OrderStatus.Processing, "پردازش"),
            (OrderStatus.Shipped,    "ارسال"),
            (OrderStatus.Delivered,  "تحویل")
        };
        int currentIdx = o.Status switch
        {
            OrderStatus.Paid       => 0,
            OrderStatus.Processing => 1,
            OrderStatus.Shipped    => 2,
            OrderStatus.Delivered  => 3,
            _                      => -1   // Pending/AwaitingPayment/Canceled/Refunded
        };
        bool isCanceled = o.Status is OrderStatus.Canceled or OrderStatus.Refunded;
        bool isPending  = o.Status is OrderStatus.Pending or OrderStatus.AwaitingPayment;
    }
    @if (isCanceled)
    {
        <div class="orders8-canceled-notice">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            این سفارش @OrderStatusView.Label(o.Status) است.
        </div>
    }
    else if (isPending)
    {
        <div class="orders8-pending-notice">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            در انتظار پرداخت — @OrderStatusView.Label(o.Status)
        </div>
    }
    else
    {
        <div class="orders8-steps">
            @for (int i = 0; i < steps.Length; i++)
            {
                var isDone = i <= currentIdx;
                var isActive = i == currentIdx;
                <div class="orders8-step @(isDone ? "is-done" : "") @(isActive ? "is-active" : "")">
                    <div class="orders8-step__dot">
                        @if (isDone && !isActive)
                        {
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>
                        }
                        else
                        {
                            <span>@(i + 1)</span>
                        }
                    </div>
                    <span class="orders8-step__label">@steps[i].Label</span>
                    @if (i < steps.Length - 1)
                    {
                        <div class="orders8-step__line @(i < currentIdx ? "is-done" : "")"></div>
                    }
                </div>
            }
        </div>
    }
</div>

@* ── اطلاعات + تغییر وضعیت + کد رهگیری *@
<div class="admin-grid-2" style="margin-bottom:16px">

    @* ستون چپ: اطلاعات سفارش + مشتری *@
    <div class="admin-panel-box">
        <h3 class="admin-box-title">اطلاعات سفارش و مشتری</h3>
        <dl class="admin-dl">
            <dt>تاریخ ثبت</dt>
            <dd>@o.CreatedAt.ToString("yyyy/MM/dd HH:mm")</dd>
            @if (o.PaidAt is DateTime paid)
            {
                <dt>تاریخ پرداخت</dt>
                <dd>@paid.ToString("yyyy/MM/dd HH:mm")</dd>
            }
            <dt>مشتری</dt>
            <dd>
                <a asp-page="/Users/Detail" asp-area="Admin" asp-route-id="@Model.Detail.UserId">@o.CustomerName</a>
                — @o.CustomerPhone
            </dd>
            @if (o.ReceiverName is not null)
            {
                <dt>تحویل‌گیرنده</dt>
                <dd>@o.ReceiverName (@o.ReceiverPhone)</dd>
                <dt>آدرس</dt>
                <dd>@o.Province، @o.City — @o.FullAddress — کد پستی @o.PostalCode</dd>
            }
            @if (!string.IsNullOrEmpty(o.ShippingMethodName))
            {
                <dt>روش ارسال</dt>
                <dd>@o.ShippingMethodName</dd>
            }
            @if (hasTracking)
            {
                <dt>کد رهگیری</dt>
                <dd><span class="orders8-tracking-badge">@o.TrackingCode</span></dd>
            }
        </dl>
    </div>

    @* ستون راست: تغییر وضعیت *@
    <div class="admin-panel-box">
        <h3 class="admin-box-title">تغییر وضعیت سفارش</h3>
        <form method="post" asp-page-handler="Status" asp-route-id="@o.Id" class="orders8-status-form">
            <div class="mb-3">
                <label class="form-label fw-semibold">وضعیت جدید</label>
                <select asp-for="NewStatus" class="form-select">
                    @foreach (var s in adminTargets)
                    {
                        <option value="@s" selected="@(Model.NewStatus == s)">@OrderStatusView.Label(s)</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">کد رهگیری (اختیاری — همزمان با تغییر وضعیت)</label>
                <input asp-for="StatusTrackingCode" class="form-control" placeholder="مثال: ۱۲۳۴۵۶۷۸۹۰" maxlength="100" />
            </div>
            <button type="submit" class="btn btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg>
                ثبت وضعیت
            </button>
        </form>
        <p class="admin-muted" style="margin-top:10px;font-size:13px">
            سفارش پرداخت‌نشده فقط قابل لغو است.
        </p>

        @* کد رهگیری مستقل *@
        <hr style="margin:16px 0;border-color:#e2e8f0" />
        <h4 class="admin-box-title">ثبت/ویرایش کد رهگیری پستی</h4>
        <p class="admin-muted" style="font-size:12.5px;margin-bottom:10px">
            کد رهگیری بدون تغییر وضعیت به‌روزرسانی می‌شود و در پنل کاربر نمایش داده می‌شود.
        </p>
        <form method="post" asp-page-handler="Tracking" asp-route-id="@o.Id" class="admin-inline-form">
            <input asp-for="TrackingCodeInput" class="form-control" placeholder="کد رهگیری پستی" maxlength="100" />
            <button type="submit" class="btn btn-outline-success">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg>
                ثبت
            </button>
        </form>
        @if (hasTracking)
        {
            <p class="admin-muted" style="margin-top:8px;font-size:12.5px">
                کد فعلی: <strong>@o.TrackingCode</strong>
            </p>
        }
    </div>
</div>

@* ── اقلام سفارش + مبالغ *@
<div class="admin-panel-box" style="margin-bottom:16px">
    <h3 class="admin-box-title">اقلام سفارش</h3>
    <table class="table admin-table orders8-items-table">
        <thead>
            <tr>
                <th>عنوان محصول</th>
                <th class="text-center">قیمت واحد (تومان)</th>
                <th class="text-center">تعداد</th>
                <th class="text-center">جمع (تومان)</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in o.Items)
        {
            <tr>
                <td>@item.ProductTitle</td>
                <td class="text-center">@item.UnitPrice.ToString("N0")</td>
                <td class="text-center">@item.Quantity</td>
                <td class="text-center">@item.LineTotal.ToString("N0")</td>
            </tr>
        }
        </tbody>
        <tfoot>
            <tr class="orders8-tfoot-row">
                <td colspan="3" class="text-start">جمع اقلام</td>
                <td class="text-center">@o.TotalAmount.ToString("N0")</td>
            </tr>
            @if (o.DiscountAmount > 0)
            {
                <tr class="orders8-tfoot-row orders8-tfoot-discount">
                    <td colspan="3" class="text-start">تخفیف</td>
                    <td class="text-center">@o.DiscountAmount.ToString("N0") −</td>
                </tr>
            }
            <tr class="orders8-tfoot-row">
                <td colspan="3" class="text-start">
                    @(string.IsNullOrEmpty(o.ShippingMethodName) ? "هزینه ارسال" : $"ارسال ({o.ShippingMethodName})")
                </td>
                <td class="text-center">
                    @(o.ShippingCost == 0 ? "رایگان" : o.ShippingCost.ToString("N0") + " تومان")
                </td>
            </tr>
            <tr class="orders8-tfoot-row orders8-tfoot-final">
                <td colspan="3" class="text-start"><strong>مبلغ نهایی</strong></td>
                <td class="text-center"><strong>@o.FinalAmount.ToString("N0") تومان</strong></td>
            </tr>
        </tfoot>
    </table>
</div>

@* ── تراکنش‌های پرداخت *@
<div class="admin-panel-box">
    <h3 class="admin-box-title">تراکنش‌های پرداخت</h3>
    <table class="table admin-table">
        <thead>
            <tr>
                <th>تاریخ</th>
                <th>مبلغ</th>
                <th>وضعیت</th>
                <th>کد پیگیری (RefId)</th>
                <th class="admin-muted">Authority</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model.Detail.Payments)
        {
            <tr>
                <td>@p.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                <td>@p.Amount.ToString("N0")</td>
                <td>
                    @switch (p.Status)
                    {
                        case PaymentStatus.Success:
                            <span class="badge bg-success">موفق</span>
                            break;
                        case PaymentStatus.Failed:
                            <span class="badge bg-danger">ناموفق</span>
                            break;
                        default:
                            <span class="badge bg-secondary">در انتظار</span>
                            break;
                    }
                </td>
                <td><strong>@(p.RefId ?? "—")</strong></td>
                <td class="admin-muted" style="font-size:12px">@(p.Authority ?? "—")</td>
            </tr>
        }
        @if (Model.Detail.Payments.Count == 0)
        {
            <tr>
                <td colspan="5" class="admin-muted text-center">تراکنشی ثبت نشده.</td>
            </tr>
        }
        </tbody>
    </table>
</div>
